{
    "version": "2026.1",
    "description": "MicroDicom is application for primary processing and preservation of medical images in DICOM format",
    "homepage": "https://www.microdicom.com/",
    "license": "Freeware",
    "architecture": {
        "64bit": {
            "url": "https://www.microdicom.com/downloads/Software/microdicom-2026.1-x64.zip",
            "hash": "01045945cc8ffd8185d78513bfac35f6d68e938dcd9a05e36547fe753734d94d"
        },
        "32bit": {
            "url": "https://www.microdicom.com/downloads/Software/microdicom-2026.1-win32.zip",
            "hash": "9daaa73e34f609420dbdde38c61671003b2b6750246e41e14350a0fa2d2231ad"
        }
    },
    "pre_install": [
        "Write-Host 'Bypassing 403 Forbidden using native curl.exe...' -ForegroundColor Cyan",
        "$arch = if ($architecture -eq '64bit') { 'x64' } else { 'win32' }",
        "$RealUrl = \"https://www.microdicom.com/downloads/Software/microdicom-$version-$arch.zip\"",
        "$ZipFile = \"$dir\\microdicom_real.zip\"",
        "curl.exe -L -A 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36' -H 'Accept: text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,*/*;q=0.8' -H 'Accept-Language: en-US,en;q=0.9' -e 'https://www.microdicom.com/downloads.html' -o \"$ZipFile\" \"$RealUrl\"",
        "if (Test-Path \"$ZipFile\") {",
        "    $size = (Get-Item \"$ZipFile\").Length",
        "    if ($size -lt 500000) {",
        "        Write-Host 'ERROR: The downloaded file is too small! The server (e.g., Cloudflare) is still blocking the script.' -ForegroundColor Red",
        "    } else {",
        "        Write-Host 'Download successful! Extracting...' -ForegroundColor Cyan",
        "        Expand-Archive -Path \"$ZipFile\" -DestinationPath \"$dir\" -Force",
        "    }",
        "    Remove-Item \"$ZipFile\" -Force",
        "}",
        "Remove-Item \"$dir\\favicon.ico\" -Force -ErrorAction SilentlyContinue"
    ],
    "shortcuts": [
        [
            "mDicom.exe",
            "MicroDicom DICOM Viewer"
        ]
    ],
    "checkver": {
        "url": "https://www.microdicom.com/downloads.html",
        "regex": "microdicom-([\\d\\.]+)-win32.zip"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://www.microdicom.com/downloads/Software/microdicom-$version-x64.zip"
            },
            "32bit": {
                "url": "https://www.microdicom.com/downloads/Software/microdicom-$version-win32.zip"
            }
        }
    }
}